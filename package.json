{
  "name": "@stableops/wallet-sdk",
  "version": "0.0.1",
  "private": false,
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@solana/web3.js": "1.98.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.16.0",
    "globals": "^15.14.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.4"
  }
}
